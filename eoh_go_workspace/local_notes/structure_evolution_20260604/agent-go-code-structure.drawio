IEVED STRATEGY CARDS&lt;br&gt;max_chars / truncation control" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#2f7d32;fillColor=#edf8ed;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="355" y="465" width="250" height="65" as="geometry"/></mxCell><mxCell id="official_run" value="official_eoh_run.py&lt;br&gt;&lt;br&gt;Build context&lt;br&gt;patch official API adapter&lt;br&gt;launch official EoH subprocess&lt;br&gt;collect summary JSON" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#a65a00;fillColor=#fff4e6;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="725" y="130" width="260" height="115" as="geometry"/></mxCell><mxCell id="smoke" value="official_eoh_smoke.py&lt;br&gt;&lt;br&gt;seed/evaluator smoke for&lt;br&gt;bp_online, tsp_construct, cvrp_construct" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#a65a00;fillColor=#fff4e6;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="725" y="270" width="260" height="70" as="geometry"/></mxCell><mxCell id="experiments" value="Other experiment scripts&lt;br&gt;&lt;br&gt;eoh_arrival_grid.py&lt;br&gt;eoh_obp_smoke.py&lt;br&gt;knapsack_smoke.py&lt;br&gt;mixer_split_smoke.py&lt;br&gt;summarizers / tables" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#a65a00;fillColor=#fff4e6;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="725" y="365" width="260" height="105" as="geometry"/></mxCell><mxCell id="runner_config" value="eoh_runner/&lt;br&gt;&lt;br&gt;config.py, runner.py, registry.py, target_spec.py, problem_spec.py, candidate_guard.py" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#a65a00;fillColor=#fff4e6;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="725" y="490" width="260" height="40" as="geometry"/></mxCell><mxCell id="official_root" value="/private/tmp/EoH-main&lt;br&gt;Official EoH repo&lt;br&gt;&lt;br&gt;examples/tsp_construct&lt;br&gt;prob.py evaluator&lt;br&gt;EoH evolutionary loop" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#1d5f91;fillColor=#eaf4ff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="1105" y="130" width="260" height="105" as="geometry"/></mxCell><mxCell id="subprocess" value="Generated run dir&lt;br&gt;&lt;br&gt;_run_official_eoh.py&lt;br&gt;results/run_log.txt&lt;br&gt;results/pops/population_generation_N.json&lt;br&gt;results/samples/samples_best.json" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#1d5f91;fillColor=#eaf4ff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="1105" y="260" width="260" height="125" as="geometry"/></mxCell><mxCell id="evaluator" value="Evaluator&lt;br&gt;&lt;br&gt;Runs generated select_next_node&lt;br&gt;on TSP n=50 instances&lt;br&gt;objective: lower route length" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#1d5f91;fillColor=#eaf4ff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="1105" y="415" width="260" height="90" as="geometry"/></mxCell><mxCell id="runs" value="local_runs/&lt;br&gt;&lt;br&gt;official_eoh_tsp_pop4_init_20260604_direct&lt;br&gt;official_eoh_tsp_pop4_targeted_20260604&lt;br&gt;official_eoh_tsp_targeted_repeats_20260604&lt;br&gt;official_eoh_tsp_targeted_gen_20260604" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#888888;fillColor=#ffffff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="355" y="640" width="305" height="130" as="geometry"/></mxCell><mxCell id="notes" value="local_notes/&lt;br&gt;&lt;br&gt;official_eoh_tsp_literature_rag_report_20260604.md&lt;br&gt;official_eoh_tsp_pop4_init_20260604.md&lt;br&gt;prompt_loop_tsp_targeted_rag_20260604.md" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#888888;fillColor=#ffffff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="695" y="640" width="310" height="130" as="geometry"/></mxCell><mxCell id="tests" value="tests/&lt;br&gt;&lt;br&gt;73 regression tests&lt;br&gt;RAG context, retriever, corpus, official runner, smoke, guard" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#888888;fillColor=#ffffff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="1040" y="640" width="225" height="130" as="geometry"/></mxCell><mxCell id="result" value="Current evidence&lt;br&gt;&lt;br&gt;Default RAG: nearest cards no gain&lt;br&gt;Targeted RAG: regret + farthest&lt;br&gt;repeat=3 stable&lt;br&gt;gen4 pop8 best=6.28736" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#9b1c1c;fillColor=#fff0f0;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="1270" y="640" width="120" height="150" as="geometry"/></mxCell><mxCell id="codebox" value="Concrete code evolution&lt;br&gt;&lt;br&gt;1 Pure EOH:&lt;br&gt;progress = d(current,dest) - (d(current,u)+d(u,dest))&lt;br&gt;score = alpha*norm_dist - (1-alpha)*norm_progress&lt;br&gt;&lt;br&gt;2 Targeted init:&lt;br&gt;farthest_rep = argmax d(current,u)&lt;br&gt;regret = second_min(endpoint cost) - min(endpoint cost)&lt;br&gt;score = norm_regret + norm_cluster + (1-norm_current_dist)&lt;br&gt;&lt;br&gt;3 Gen4 best:&lt;br&gt;iso = mean distance(cand, others + destination)&lt;br&gt;regret = max(0, best_two_hop - d_current)&lt;br&gt;score = (0.4*iso + 0.6*regret) / d_current" style="whiteSpace=wrap;html=1;rounded=1;dashed=1;strokeColor=#555555;fillColor=#ffffff;fontSize=11;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="40" y="360" width="250" height="410" as="geometry"/></mxCell><mxCell id="e_problem_runner" value="problem spec" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="problem" target="official_run"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_model_runner" value="API env" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="model" target="official_run"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_corpus_build" value="load" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="corpus" target="build"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_build_retrieve" value="filtered pool" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="build" target="retrieve"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_retrieve_prompt" value="selected cards" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="retrieve" target="prompt"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_prompt_runner" value="context file" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="prompt" target="official_run"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_runner_official" value="invoke" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="official_run" target="official_root"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_official_subprocess" value="run" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="official_root" target="subprocess"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_sub_eval" value="evaluate code" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="subprocess" target="evaluator"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_sub_runs" value="artifacts" style="endArrow=block;html=1;rounded=0;strokeColor=#555555;fontSize=11;" edge="1" parent="1" source="subprocess" target="runs"><mxGeometry relative="1" as="geometry"/></mxCell><mxCel