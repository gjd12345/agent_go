<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="40" width="80" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="grid" value="Define Grid&#xa;(problems x densities&#xa;x arrival_scales)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
      <mxGeometry x="200" y="30" width="160" height="80" as="geometry"/>
    </mxCell>

    <mxCell id="arm" value="Ablation Pair?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
      <mxGeometry x="440" y="30" width="140" height="80" as="geometry"/>
    </mxCell>

    <mxCell id="bsl" value="Baseline Arm&#xa;(no RAG context)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
      <mxGeometry x="660" y="10" width="150" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="rag" value="RAG Arm&#xa;(with context injection)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
      <mxGeometry x="660" y="90" width="150" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="cell_loop" value="For each cell" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
      <mxGeometry x="900" y="20" width="140" height="80" as="geometry"/>
    </mxCell>

    <mxCell id="eoh_run" value="run_v0_eoh()&#xa;EOH Evolution&#xa;pop=8, gen=1..N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
      <mxGeometry x="900" y="140" width="160" height="80" as="geometry"/>
    </mxCell>

    <mxCell id="sa_eval" value="SA Evaluation&#xa;(seed_J, seed_Res)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
      <mxGeometry x="1120" y="60" width="150" height="80" as="geometry"/>
    </mxCell>

    <mxCell id="guard" value="Candidate Guard&#xa;classify &amp; select" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
      <mxGeometry x="1120" y="170" width="150" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="partial" value="Write partial.json&#xa;(after each cell)" style="shape=document;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
      <mxGeometry x="1330" y="60" width="140" height="80" as="geometry"/>
    </mxCell>

    <mxCell id="result" value="Write results.json&#xa;+ markdown table" style="shape=document;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
      <mxGeometry x="1330" y="170" width="150" height="80" as="geometry"/>
    </mxCell>

    <mxCell id="pair_done" value="Both arms done?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
      <mxGeometry x="1530" y="30" width="140" height="80" as="geometry"/>
    </mxCell>

    <mxCell id="summary_op" value="summarize_rag_ablation()&#xa;paired comparison&#xa;delta_J, delta_valid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
      <mxGeometry x="1530" y="160" width="180" height="85" as="geometry"/>
    </mxCell>

    <mxCell id="end_node" value="Done" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1780" y="95" width="80" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="n1" edge="1" parent="1" source="start" target="grid" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n2" edge="1" parent="1" source="grid" target="arm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n3" value="yes" edge="1" parent="1" source="arm" target="bsl" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n4" value="yes" edge="1" parent="1" source="arm" target="rag" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n5" edge="1" parent="1" source="bsl" target="cell_loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n6" edge="1" parent="1" source="rag" target="cell_loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n7" value="each cell" edge="1" parent="1" source="cell_loop" target="eoh_run" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n8" edge="1" parent="1" source="eoh_run" target="sa_eval" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n9" edge="1" parent="1" source="sa_eval" target="guard" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n10" edge="1" parent="1" source="guard" target="partial" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n11" edge="1" parent="1" source="guard" target="result" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n12" value="last cell?" edge="1" parent="1" source="partial" target="pair_done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n13" edge="1" parent="1" source="result" target="pair_done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n14" value="yes" edge="1" parent="1" source="pair_done" target="summary_op" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="n15" edge="1" parent="1" source="summary_op" target="end_node" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="loop_cell" value="next cell" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;" edge="1" parent="1" source="pair_done" target="cell_loop">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="1600" y="-20"/>
          <mxPoint x="970" y="-20"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="loop_arm" value="next arm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;" edge="1" parent="1" source="pair_done" target="arm">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="1600" y="-60"/>
          <mxPoint x="510" y="-60"/>
        </Array>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
