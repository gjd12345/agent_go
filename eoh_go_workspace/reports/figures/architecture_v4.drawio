    <mxCell id="tool1" value="&lt;b&gt;1. Trace Reader&lt;/b&gt;&lt;br&gt;Reads: run_summary&lt;br&gt;rag_trace, run_index&lt;br&gt;Output: structured trace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a5d6a7;strokeColor=#43a047;strokeWidth=1.5;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="1">
