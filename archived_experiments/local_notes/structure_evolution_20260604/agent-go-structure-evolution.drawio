<mxfile host="app.diagrams.net"><diagram id="agent-go-structure-evolution" name="agent_go structure evolution"><mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="agent_go CLV Harness + Official EoH / TSP Targeted RAG Evolution" style="text;html=1;fontSize=20;fontStyle=1;strokeColor=none;fillColor=none;" vertex="1" parent="1"><mxGeometry x="55" y="20" width="1180" height="36" as="geometry"/></mxCell><mxCell id="io" value="Heuristic In&amp;amp;Out&lt;br&gt;&lt;br&gt;Input: current_node, destination_node, unvisited_nodes, distance_matrix&lt;br&gt;Output: next_node (int)&lt;br&gt;Objective: lower TSP route length" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#888888;fillColor=#ffffff;fontSize=13;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1"><mxGeometry x="55" y="70" width="230" height="130" as="geometry"/></mxCell><mxCell id="structure" value="Script Structure (Python)&lt;br&gt;&lt;br&gt;eoh_runner/: config, runner, registry, guard, target_spec&lt;br&gt;rag/: schemas, build_corpus, retriever, prompt_context&lt;br&gt;experiments/: official_eoh_run, smoke, grid, summaries&lt;br&gt;tests/: 73 regression tests" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#1d5f91;fillColor=#eaf4ff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="55" y="230" width="330" height="180" as="geometry"/></mxCell><mxCell id="dataflow" value="Data Flow&lt;br&gt;&lt;br&gt;Corpus JSONL -&amp;gt; retrieve cards -&amp;gt; prompt context -&amp;gt; official EoH runner -&amp;gt; population JSON -&amp;gt; local notes/report" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#2f7d32;fillColor=#edf8ed;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="55" y="440" width="330" height="125"