rrow=none;html=1;rounded=0;strokeWidth=5;strokeColor=#b45f06;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="" style="endArrow=none;html=1;rounded=0;strokeWidth=5;strokeColor=#b45f06;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="" style="endArrow=none;html=1;rounded=0;strokeWidth=5;strokeColor=#b45f06;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="" style="endArrow=none;html=1;rounded=0;strokeWidth=5;strokeColor=#b45f06;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="" style="endArrow=none;html=1;rounded=0;strokeWidth=5;strokeColor=#b45f06;" edge="1" parent="1" source="p5" target="p6"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c1" value="API-only&lt;br&gt;contract + signature&lt;br&gt;small gain: -0.0495" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#a65a00;fillColor=#fff4e6;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="515" y="580" width="150" height="80" as="geometry"/></mxCell><mxCell id="c2" value="Default RAG&lt;br&gt;nearest insertion + nearest neighbor&lt;br&gt;no gain" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#999999;fillColor=#fffdf8;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="630" y="585" width="170" height="80" as="geometry"/></mxCell><mxCell id="c3" value="Targeted RAG&lt;br&gt;regret + farthest cards&lt;br&gt;init best 6.511" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#a65a00;fillColor=#fff4e6;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="770" y="435" width="190" height="82" as="geometry"/></mxCell><mxCell id="c4" value="Repeat=3&lt;br&gt;3/3 below pure/API&lt;br&gt;median 6.500, min 6.305" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#a65a00;fillColor=#fff4e6;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="870" y="300" width="190" height="90" as="geometry"/></mxCell><mxCell id="c5" value="Gen4 pop8&lt;br&gt;best 6.28736&lt;br&gt;init 6.51 -&amp;gt; gen2 6.32 -&amp;gt; gen3 6.29" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#a65a00;fillColor=#fff4e6;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="1000" y="270" width="220" height="105" as="geometry"/></mxCell><mxCell id="c6" value="Gen8 pop8&lt;br&gt;plateau 6.493&lt;br&gt;more generations did not dominate gen4" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#999999;fillColor=#fffdf8;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="1110" y="600" width="210" height="90" as="geometry"/></mxCell><mxCell id="ec1" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="c1" target="p1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec2" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="c2" target="p2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec3" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="c3" target="p3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec4" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="c4" target="p4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec5" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="c5" target="p5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec6" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="c6" target="p6"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="human" value="# Pure EOH baseline&lt;br&gt;&lt;br&gt;progress = d(current,dest) - (d(current,u)+d(u,dest))&lt;br&gt;score = alpha*norm_dist - (1-alpha)*norm_progress&lt;br&gt;return argmin(score)" style="whiteSpace=wrap;html=1;rounded=1;dashed=1;strokeColor=#555555;fillColor=#ffffff;fontSize=12;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1"><mxGeometry x="430" y="95" width="300" height="145" as="geometry"/></mxCell><mxCell id="targeted" value="# Targeted RAG init&lt;br&gt;&lt;br&gt;farthest_rep = argmax d(current,u)&lt;br&gt;regret = second_min(endpoint cost) - min(endpoint cost)&lt;br&gt;score = norm_regret + norm_cluster + (1-norm_current_dist)&lt;br&gt;return argmax(score)" style="whiteSpace=wrap;html=1;rounded=1;dashed=1;strokeColor=#555555;fillColor=#ffffff;fontSize=12;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1"><mxGeometry x="760" y="95" width="350" height="165" as="geometry"/></mxCell><mxCell id="final" value="# Gen4 best heuristic&lt;br&gt;&lt;br&gt;for cand in unvisited:&lt;br&gt;  iso = mean distance(cand, others + destination)&lt;br&gt;  regret = max(0, best_two_hop - d_current)&lt;br&gt;  score = (0.4*iso + 0.6*regret) / d_current&lt;br&gt;return argmax(score)" style="whiteSpace=wrap;html=1;rounded=1;dashed=1;strokeColor=#555555;fillColor=#ffffff;fontSize=12;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1"><mxGeometry x="1135" y="95" width="350" height="165" as="geometry"/></mxCell><mxCell id="finaledge" value="best code" style="endArrow=block;html=1;dashed=1;strokeColor=#555555;" edge="1" parent="1" source="p5" target="final"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="d1" value="Corpus&lt;br&gt;algorithm_cards.jsonl&lt;br&gt;api_constraints.jsonl" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#1d5f91;fillColor=#eaf4ff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="420" y="900" width="150" height="70" as="geometry"/></mxCell><mxCell id="d2" value="Retrieval&lt;br&gt;retriever.py&lt;br&gt;score query terms" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#1d5f91;fillColor=#eaf4ff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="600" y="900" width="150" height="70" as="geometry"/></mxCell><mxCell id="d3" value="Prompt&lt;br&gt;prompt_context.py&lt;br&gt;API + Strategy cards" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#1d5f91;fillColor=#eaf4ff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="780" y="900" width="160" height="70" as="geometry"/></mxCell><mxCell id="d4" value="Official Runner&lt;br&gt;official_eoh_run.py&lt;br&gt;EoH subprocess" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#1d5f91;fillColor=#eaf4ff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="980" y="900" width="160" height="70" as="geometry"/></mxCell><mxCell id="d5" value="Evidence&lt;br&gt;summary JSON&lt;br&gt;local_notes/*.md" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#1d5f91;fillColor=#eaf4ff;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="1180" y="900" width="160" height="70" as="geometry"/></mxCell><mxCell id="edge_d1" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#1d5f91;" edge="1" parent="1" source="d1" target="d2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_d2" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#1d5f91;" edge="1" parent="1" source="d2" target="d3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_d3" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#1d5f91;" edge="1" parent="1" source="d3" target="d4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_d4" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#1d5f91;" edge="1" parent="1" source="d4" target="d5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="legend" value="Legend&lt;br&gt;red/black circles: objective checkpoints&lt;br&gt;orange boxes: heuristic/RAG interventions&lt;br&gt;blue boxes: script/data modules&lt;br&gt;dashed boxes: concrete generated code examples" style="whiteSpace=wrap;html=1;rounded=0;strokeColor=#999999;fillColor=#fffdf8;fontSize=12;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1"><mxGeometry x="1260" y="320" width="250" height="125" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>